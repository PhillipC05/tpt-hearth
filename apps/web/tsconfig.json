{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "node"
    ],
    "paths": {
      "@tpt-hearth/config": [
        "../../packages/config/src/index.ts"
      ],
      "@tpt-hearth/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@tpt-hearth/db": [
        "../../packages/db/src/index.ts"
      ],
      "@tpt-hearth/crypto": [
        "../../packages/crypto/src/index.ts"
      ],
      "@tpt-hearth/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@/*": [
        "src/*"
      ]
    },
    "esModuleInterop": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
