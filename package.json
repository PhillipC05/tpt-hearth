{
  "name": "tpt-hearth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:generate": "pnpm --filter @tpt-hearth/db generate",
    "db:migrate": "pnpm --filter @tpt-hearth/db migrate",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}