# =============================================================================
# `tpt hearth` — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#
#   cp .env.example .env
#
# All variables are required unless marked as optional.
# =============================================================================

# -- App URLs -----------------------------------------------------------------
# Public URL of the Next.js app. Must match the deployed domain exactly.
# In production, use https://.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public WebSocket URL. Use wss:// in production.
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# -- Database -----------------------------------------------------------------
# SQLite:   file:.data/hearth.sqlite
# Postgres: postgresql://user:password@host:5432/tpt_hearth
DATABASE_URL=file:.data/hearth.sqlite

# -- Environment --------------------------------------------------------------
# Set to "production" in deployed environments.
NODE_ENV=development

# -- Auth ---------------------------------------------------------------------
# Authentication mode. Options:
#   invite_code  — Sign-up via invite codes only (recommended for closed communities)
#   magic_link   — Passwordless email magic links
#   username     — Simple username/password
#   oauth        — OAuth provider (Google currently)
#   local_demo   — One-click demo auth (development only)
AUTH_MODE=invite_code

# Mirrors AUTH_MODE for client-side access.
NEXT_PUBLIC_AUTH_MODE=invite_code

# Allow one-click demo auth. Disable in production.
DEMO_AUTH_ALLOWED=true

# Allow debug magic links (printed to console). Disable in production.
MAGIC_LINK_ALLOW_DEBUG_LINKS=true

# -- OAuth (Google) -----------------------------------------------------------
# Enable Google OAuth sign-in.
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=false

# Google OAuth credentials (required if OAuth is enabled).
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# OAuth redirect URI. Must match the URI registered in Google Cloud Console.
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback

# -- Production Database (optional) -------------------------------------------
# Uncomment and set this when migrating to PostgreSQL in production.
# DATABASE_URL=postgresql://user:password@localhost:5432/tpt_hearth

# -- Additional Notes ---------------------------------------------------------
# Production checklist:
#   [ ] NEXT_PUBLIC_APP_URL uses https://
#   [ ] NEXT_PUBLIC_WS_URL uses wss://
#   [ ] NODE_ENV is "production"
#   [ ] DEMO_AUTH_ALLOWED is false
#   [ ] MAGIC_LINK_ALLOW_DEBUG_LINKS is false
#   [ ] OAuth secrets are stored securely (not committed to git)
#
# See docs/deployment.md for full deployment guidance.